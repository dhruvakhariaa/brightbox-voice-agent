# --- LLM (task brief permits Gemini OR OpenAI only) ---
# LLM_PROVIDER selects which one is used. Set to `gemini` for the free option
# (Google AI Studio Flash models), or `openai` (paid, but pennies for testing).
# You only need to fill the key for the provider you pick.
LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini: use a Google AI Studio key (https://aistudio.google.com/apikey) -- NOT Vertex AI.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- STT/TTS provider selection ---
# sarvam is primary (best for Indian-accented English/Hindi callers).
# Flip both to deepgram/cartesia if the Sarvam plugin misbehaves -- no code changes needed.
STT_PROVIDER=sarvam
TTS_PROVIDER=sarvam

SARVAM_API_KEY=
SARVAM_STT_MODEL=saarika:v2.5
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_VOICE=anushka

DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# --- Twilio (required) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Only needed for scripts/place_call.py (agent calls you, to avoid ISD from India).
# All E.164 format, e.g. +14155551234 / +919812345678.
TWILIO_FROM_NUMBER=     # your Twilio number
MY_NUMBER=              # your verified phone that should receive the call
PUBLIC_BASE_URL=        # your ngrok https URL, e.g. https://abcd.ngrok-free.dev

# --- Server ---
PORT=8000

# --- RAG / call tuning (sane defaults already in app/config.py) ---
# Two-tier relevance gate: >=STRONG answer, WEAK..STRONG gray zone, <WEAK fall back.
SIMILARITY_STRONG=0.35
SIMILARITY_WEAK=0.28
IDLE_TIMEOUT_SECS=18
MAX_ERRORS_BEFORE_GIVEUP=3

# --- Audio / turn-taking (raise VAD_STOP_SECS if the agent keeps cutting you off) ---
STT_SAMPLE_RATE=16000
VAD_STOP_SECS=0.8
# TTS speaking speed: 1.0 = normal, 0.9 = ~10% slower (clearer). Lower = slower.
TTS_PACE=0.9
# Real-time gain control on the caller's audio before STT (helps quiet phone speech).
# Set to false if it ever sounds off.
AUDIO_ENHANCE=true
